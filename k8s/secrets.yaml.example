# Template — copy to secrets.yaml and fill in real base64 values.
# Generate base64 values:  echo -n 'value' | base64
# NEVER commit the filled-in secrets.yaml to version control.
apiVersion: v1
kind: Secret
metadata:
  name: backend-secrets
  namespace: fedex
type: Opaque
data:
  POSTGRES_CONNECTION_STRING: <base64-encoded-value>
  AZURE_EMAIL_CONNECTION_STRING: <base64-encoded-value>
  AZURE_EMAIL_FROM_ADDRESS: <base64-encoded-value>
  AZURE_FUNCTION_APP_URL: <base64-encoded-value>
  AZURE_FUNCTION_APP_KEY: <base64-encoded-value>
