{
  "properties": {
    "activities": [
      {
        "name": "CopyBusinesses",
        "type": "Copy",
        "dependsOn": [],
        "policy": {
          "timeout": "7.00:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "source": {
            "type": "AzurePostgreSqlSource",
            "query": "SELECT id::text, name, account_number, address, contact_email, phone, created_at AT TIME ZONE 'UTC' AS created_at FROM businesses"
          },
          "sink": {
            "type": "SqlDWSink",
            "allowPolyBase": false,
            "writeBehavior": "Insert"
          },
          "enableStaging": false
        },
        "inputs": [
          {
            "referenceName": "SourcePostgres",
            "type": "DatasetReference"
          }
        ],
        "outputs": [
          {
            "referenceName": "SinkBusinesses",
            "type": "DatasetReference"
          }
        ]
      },
      {
        "name": "CopyOrders",
        "type": "Copy",
        "dependsOn": [
          {
            "activity": "CopyBusinesses",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "policy": {
          "timeout": "7.00:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "source": {
            "type": "AzurePostgreSqlSource",
            "query": "SELECT id::text, business_id::text, tracking_number, origin, destination, status::text, weight_lbs, service_type::text, estimated_delivery, actual_delivery, created_at AT TIME ZONE 'UTC' AS created_at, updated_at AT TIME ZONE 'UTC' AS updated_at FROM orders"
          },
          "sink": {
            "type": "SqlDWSink",
            "allowPolyBase": false,
            "writeBehavior": "Insert"
          },
          "enableStaging": false
        },
        "inputs": [
          {
            "referenceName": "SourcePostgres",
            "type": "DatasetReference"
          }
        ],
        "outputs": [
          {
            "referenceName": "SinkOrders",
            "type": "DatasetReference"
          }
        ]
      },
      {
        "name": "CopyShipmentEvents",
        "type": "Copy",
        "dependsOn": [
          {
            "activity": "CopyOrders",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "policy": {
          "timeout": "7.00:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "source": {
            "type": "AzurePostgreSqlSource",
            "query": "SELECT id::text, order_id::text, event_type::text, location, description, occurred_at AT TIME ZONE 'UTC' AS occurred_at FROM shipment_events"
          },
          "sink": {
            "type": "SqlDWSink",
            "allowPolyBase": false,
            "writeBehavior": "Insert"
          },
          "enableStaging": false
        },
        "inputs": [
          {
            "referenceName": "SourcePostgres",
            "type": "DatasetReference"
          }
        ],
        "outputs": [
          {
            "referenceName": "SinkShipmentEvents",
            "type": "DatasetReference"
          }
        ]
      },
      {
        "name": "CopyNotifications",
        "type": "Copy",
        "dependsOn": [
          {
            "activity": "CopyOrders",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "policy": {
          "timeout": "7.00:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "source": {
            "type": "AzurePostgreSqlSource",
            "query": "SELECT id::text, order_id::text, business_id::text, type::text, message, CASE WHEN is_read THEN 1 ELSE 0 END AS is_read, created_at AT TIME ZONE 'UTC' AS created_at FROM notifications"
          },
          "sink": {
            "type": "SqlDWSink",
            "allowPolyBase": false,
            "writeBehavior": "Insert"
          },
          "enableStaging": false
        },
        "inputs": [
          {
            "referenceName": "SourcePostgres",
            "type": "DatasetReference"
          }
        ],
        "outputs": [
          {
            "referenceName": "SinkNotifications",
            "type": "DatasetReference"
          }
        ]
      }
    ]
  }
}
