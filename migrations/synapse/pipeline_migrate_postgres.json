{
  "properties": {
    "activities": [
      {
        "name": "TruncateAllTables",
        "type": "Script",
        "dependsOn": [],
        "policy": {
          "timeout": "0.00:10:00",
          "retry": 2,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "scripts": [
            {
              "type": "NonQuery",
              "text": "TRUNCATE TABLE dbo.notifications; TRUNCATE TABLE dbo.shipment_events; TRUNCATE TABLE dbo.orders; TRUNCATE TABLE dbo.businesses;"
            }
          ]
        },
        "linkedServiceName": {
          "referenceName": "fedexsynapseus-WorkspaceDefaultSqlServer",
          "type": "LinkedServiceReference",
          "parameters": {
            "DBName": "fedexpool"
          }
        }
      },
      {
        "name": "CopyBusinesses",
        "type": "Copy",
        "dependsOn": [
          {
            "activity": "TruncateAllTables",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "policy": {
          "timeout": "0.01:00:00",
          "retry": 3,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "source": {
            "type": "AzurePostgreSqlSource",
            "query": "SELECT id::text, name, account_number, address, contact_email, phone, created_at AT TIME ZONE 'UTC' AS created_at FROM public.businesses"
          },
          "sink": {
            "type": "SqlDWSink",
            "allowCopyCommand": true,
            "writeBehavior": "Insert"
          },
          "enableStaging": true,
          "stagingSettings": {
            "linkedServiceName": {
              "referenceName": "SynapseStorageStaging",
              "type": "LinkedServiceReference"
            },
            "path": "synapse/staging"
          }
        },
        "inputs": [
          {
            "referenceName": "PostgresSourceDataset",
            "type": "DatasetReference"
          }
        ],
        "outputs": [
          {
            "referenceName": "SinkBusinesses",
            "type": "DatasetReference"
          }
        ]
      },
      {
        "name": "ValidateBusinesses",
        "type": "Lookup",
        "dependsOn": [
          {
            "activity": "CopyBusinesses",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "policy": {
          "timeout": "0.00:10:00",
          "retry": 2,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "source": {
            "type": "SqlDWSource",
            "sqlReaderQuery": "SELECT 'businesses' AS table_name, COUNT(*) AS row_count FROM dbo.businesses"
          },
          "dataset": {
            "referenceName": "SinkBusinesses",
            "type": "DatasetReference"
          }
        }
      },
      {
        "name": "CopyOrders",
        "type": "Copy",
        "dependsOn": [
          {
            "activity": "ValidateBusinesses",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "policy": {
          "timeout": "0.01:00:00",
          "retry": 3,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "source": {
            "type": "AzurePostgreSqlSource",
            "query": "SELECT id::text, business_id::text, tracking_number, origin, destination, status::text, weight_lbs, service_type::text, estimated_delivery, actual_delivery, created_at AT TIME ZONE 'UTC' AS created_at, updated_at AT TIME ZONE 'UTC' AS updated_at FROM public.orders"
          },
          "sink": {
            "type": "SqlDWSink",
            "allowCopyCommand": true,
            "writeBehavior": "Insert"
          },
          "enableStaging": true,
          "stagingSettings": {
            "linkedServiceName": {
              "referenceName": "SynapseStorageStaging",
              "type": "LinkedServiceReference"
            },
            "path": "synapse/staging"
          }
        },
        "inputs": [
          {
            "referenceName": "PostgresSourceDataset",
            "type": "DatasetReference"
          }
        ],
        "outputs": [
          {
            "referenceName": "SinkOrders",
            "type": "DatasetReference"
          }
        ]
      },
      {
        "name": "ValidateOrders",
        "type": "Lookup",
        "dependsOn": [
          {
            "activity": "CopyOrders",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "policy": {
          "timeout": "0.00:10:00",
          "retry": 2,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "source": {
            "type": "SqlDWSource",
            "sqlReaderQuery": "SELECT 'orders' AS table_name, COUNT(*) AS row_count FROM dbo.orders"
          },
          "dataset": {
            "referenceName": "SinkOrders",
            "type": "DatasetReference"
          }
        }
      },
      {
        "name": "CopyShipmentEvents",
        "type": "Copy",
        "dependsOn": [
          {
            "activity": "ValidateOrders",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "policy": {
          "timeout": "0.01:00:00",
          "retry": 3,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "source": {
            "type": "AzurePostgreSqlSource",
            "query": "SELECT id::text, order_id::text, event_type::text, location, description, occurred_at AT TIME ZONE 'UTC' AS occurred_at FROM public.shipment_events"
          },
          "sink": {
            "type": "SqlDWSink",
            "allowCopyCommand": true,
            "writeBehavior": "Insert"
          },
          "enableStaging": true,
          "stagingSettings": {
            "linkedServiceName": {
              "referenceName": "SynapseStorageStaging",
              "type": "LinkedServiceReference"
            },
            "path": "synapse/staging"
          }
        },
        "inputs": [
          {
            "referenceName": "PostgresSourceDataset",
            "type": "DatasetReference"
          }
        ],
        "outputs": [
          {
            "referenceName": "SinkShipmentEvents",
            "type": "DatasetReference"
          }
        ]
      },
      {
        "name": "CopyNotifications",
        "type": "Copy",
        "dependsOn": [
          {
            "activity": "ValidateOrders",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "policy": {
          "timeout": "0.01:00:00",
          "retry": 3,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "source": {
            "type": "AzurePostgreSqlSource",
            "query": "SELECT id::text, order_id::text, business_id::text, type::text, message, CASE WHEN is_read THEN 1 ELSE 0 END AS is_read, created_at AT TIME ZONE 'UTC' AS created_at FROM public.notifications"
          },
          "sink": {
            "type": "SqlDWSink",
            "allowCopyCommand": true,
            "writeBehavior": "Insert"
          },
          "enableStaging": true,
          "stagingSettings": {
            "linkedServiceName": {
              "referenceName": "SynapseStorageStaging",
              "type": "LinkedServiceReference"
            },
            "path": "synapse/staging"
          }
        },
        "inputs": [
          {
            "referenceName": "PostgresSourceDataset",
            "type": "DatasetReference"
          }
        ],
        "outputs": [
          {
            "referenceName": "SinkNotifications",
            "type": "DatasetReference"
          }
        ]
      },
      {
        "name": "ValidateShipmentEvents",
        "type": "Lookup",
        "dependsOn": [
          {
            "activity": "CopyShipmentEvents",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "policy": {
          "timeout": "0.00:10:00",
          "retry": 2,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "source": {
            "type": "SqlDWSource",
            "sqlReaderQuery": "SELECT 'shipment_events' AS table_name, COUNT(*) AS row_count FROM dbo.shipment_events"
          },
          "dataset": {
            "referenceName": "SinkShipmentEvents",
            "type": "DatasetReference"
          }
        }
      },
      {
        "name": "ValidateNotifications",
        "type": "Lookup",
        "dependsOn": [
          {
            "activity": "CopyNotifications",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "policy": {
          "timeout": "0.00:10:00",
          "retry": 2,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "source": {
            "type": "SqlDWSource",
            "sqlReaderQuery": "SELECT 'notifications' AS table_name, COUNT(*) AS row_count FROM dbo.notifications"
          },
          "dataset": {
            "referenceName": "SinkNotifications",
            "type": "DatasetReference"
          }
        }
      }
    ]
  }
}
