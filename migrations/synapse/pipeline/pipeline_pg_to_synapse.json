{
  "name": "PgToSynapseMigration",
  "properties": {
    "description": "Migrates all tables from PostgreSQL to Azure Synapse dedicated SQL pool",
    "activities": [
      {
        "name": "Copy_businesses",
        "type": "Copy",
        "dependsOn": [],
        "typeProperties": {
          "source": {
            "type": "AzurePostgreSqlSource",
            "query": "SELECT id::text, name, account_number, address, contact_email, phone, created_at AT TIME ZONE 'UTC' AS created_at FROM businesses"
          },
          "sink": {
            "type": "SqlDWSink",
            "writeBehavior": "Insert",
            "tableOption": "none"
          },
          "enableStaging": false
        },
        "inputs": [
          {
            "referenceName": "PgSourceDataset",
            "type": "DatasetReference"
          }
        ],
        "outputs": [
          {
            "referenceName": "SynapseBusinesses",
            "type": "DatasetReference"
          }
        ]
      },
      {
        "name": "Copy_orders",
        "type": "Copy",
        "dependsOn": [
          {
            "activity": "Copy_businesses",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "typeProperties": {
          "source": {
            "type": "AzurePostgreSqlSource",
            "query": "SELECT id::text, business_id::text, tracking_number, origin, destination, status::text, weight_lbs, service_type::text, estimated_delivery, actual_delivery, created_at AT TIME ZONE 'UTC' AS created_at, updated_at AT TIME ZONE 'UTC' AS updated_at FROM orders"
          },
          "sink": {
            "type": "SqlDWSink",
            "writeBehavior": "Insert",
            "tableOption": "none"
          },
          "enableStaging": false
        },
        "inputs": [
          {
            "referenceName": "PgSourceDataset",
            "type": "DatasetReference"
          }
        ],
        "outputs": [
          {
            "referenceName": "SynapseOrders",
            "type": "DatasetReference"
          }
        ]
      },
      {
        "name": "Copy_shipment_events",
        "type": "Copy",
        "dependsOn": [
          {
            "activity": "Copy_orders",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "typeProperties": {
          "source": {
            "type": "AzurePostgreSqlSource",
            "query": "SELECT id::text, order_id::text, event_type::text, location, description, occurred_at AT TIME ZONE 'UTC' AS occurred_at FROM shipment_events"
          },
          "sink": {
            "type": "SqlDWSink",
            "writeBehavior": "Insert",
            "tableOption": "none"
          },
          "enableStaging": false
        },
        "inputs": [
          {
            "referenceName": "PgSourceDataset",
            "type": "DatasetReference"
          }
        ],
        "outputs": [
          {
            "referenceName": "SynapseShipmentEvents",
            "type": "DatasetReference"
          }
        ]
      },
      {
        "name": "Copy_notifications",
        "type": "Copy",
        "dependsOn": [
          {
            "activity": "Copy_orders",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "typeProperties": {
          "source": {
            "type": "AzurePostgreSqlSource",
            "query": "SELECT id::text, order_id::text, business_id::text, type::text, message, CASE WHEN is_read THEN 1 ELSE 0 END AS is_read, created_at AT TIME ZONE 'UTC' AS created_at FROM notifications"
          },
          "sink": {
            "type": "SqlDWSink",
            "writeBehavior": "Insert",
            "tableOption": "none"
          },
          "enableStaging": false
        },
        "inputs": [
          {
            "referenceName": "PgSourceDataset",
            "type": "DatasetReference"
          }
        ],
        "outputs": [
          {
            "referenceName": "SynapseNotifications",
            "type": "DatasetReference"
          }
        ]
      }
    ]
  }
}
